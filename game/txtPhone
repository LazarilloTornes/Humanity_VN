default contacts = ["AA Mamá", "AA Papá"]
default current_call = ""
default inventario = []

screen phone(): 

    add "phone.png":
        xalign 0.5
        yalign 0.5
    imagebutton:
            idle "closebutton.png"
            hover "closebutton.png"
            xpos 300
            ypos 400
            action Hide("phone")
    imagebutton:
            idle "contactsbutton.png"
            hover "contactsbutton.png"
            xsize 60
            ysize 60
            xpos 880
            ypos 340
            action Hide("phone"), Function(renpy.call("call_handler"))               
screen contacts():
   
    add "phone.png":
        xalign 0.5
        yalign 0.5
   
    
    imagebutton:
        idle "closebutton.png"
        hover "closebutton.png"
        xpos 300
        ypos 400
        action Hide("contacts") 
           
       
       
    viewport:
        xsize 210
        ysize 125
        xpos 870
        ypos 350
        scrollbars "vertical"
        mousewheel True
        draggable True
            

        vbox:
            spacing 10
            
            for i in contacts:
                textbutton "[i]":
                    text_style "txtContacts"
                    action [Return(i),SetVariable("current_call", i),Hide("contacts")]
                    # if current_call == "AA Mamá":        
                    #     renpy.call(" response_call_mum")            
