                    #     renpy.call(" response_call_dad")
                    # elif current_call == "661":
                    #     renpy.call(" response_call_661")                                          
                    # elif current_call == "627":                    
                    #     renpy.call(" response_call_627")      
                            
label call_handler:
    $ renpy.restart_interaction()
    $ current_call = renpy.call_screen("contacts")
    if current_call == "AA Mamá":        
        call response_call_mum        
    elif current_call == "AA Papá":                    
        call response_call_dad
    elif current_call == "661":
        call response_call_661
    elif current_call == "627":                  
        call response_call_627
